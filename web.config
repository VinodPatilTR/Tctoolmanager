<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Route ALL requests through iisnode → sql-server.js -->
    <handlers>
      <add name="iisnode" path="sql-server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="NodeApp" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="sql-server.js" />
        </rule>
      </rules>
    </rewrite>
    <!-- Preserve Node.js response headers (CORS, status codes) -->
    <httpErrors existingResponse="PassThrough" />
    <iisnode
      watchedFiles="web.config;*.js"
      loggingEnabled="false"
      nodeProcessCommandLine="node.exe" />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
